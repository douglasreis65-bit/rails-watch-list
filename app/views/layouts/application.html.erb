<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails Watch List" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <!-- NAVBAR GLOBAL -->
    <nav class="navbar navbar-dark bg-black px-4">
      <span class="navbar-brand">🎬 MovieLists</span>

      <div>
        <%= link_to "Minhas listas", lists_path, class: "btn btn-outline-light me-2" %>
        <%= link_to "Nova lista", new_list_path, class: "btn btn-warning" %>
      </div>
    </nav>

    <!-- CONTEÚDO DAS PÁGINAS -->
    <%= yield %>

  </body>
</html>
