<div class="container mt-5">

  <%= link_to "Adicionar filme", new_list_bookmark_path(@list), class: "btn btn-warning mb-4" %>

  <h1 class="mb-4"><%= @list.name %></h1>

  <div class="row">

    <% @list.bookmarks.each do |bookmark| %>

      <div class="col-md-3 mb-4">

        <div class="movie-card">

          <div class="poster-wrapper">

            <img src="<%= bookmark.movie.poster_url %>" class="movie-poster">

            <%= link_to bookmark_path(bookmark),
              data: { turbo_method: :delete, turbo_confirm: "Remover filme da lista?" },
              class: "delete-icon" do %>

              <i class="fa-solid fa-trash"></i>

            <% end %>

          </div>

          <div class="movie-info">

            <h5><%= bookmark.movie.title %></h5>

            <p class="movie-overview">
              <%= truncate(bookmark.movie.overview, length: 100) %>
            </p>

            <p class="movie-rating">
              ⭐ <%= bookmark.movie.rating %>
            </p>

            <p class="bookmark-comment">
              "<%= bookmark.comment %>"
            </p>

          </div>

        </div>

      </div>

    <% end %>

  </div>

</div>

<h1><%= @list.name %></h1>

<% if @list.comment.present? %>
  <p><%= @list.comment %></p>
<% else %>
  <p>Sem comentário ainda.</p>
<% end %>

<%= link_to "Adicionar comentário", edit_list_path(@list) %>
