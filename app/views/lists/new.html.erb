<div class="list-new-page">

  <div class="list-hero">
    <h1>Criar nova lista</h1>
    <p>Escolha vários filmes para começar</p>
  </div>

  <div class="container">

    <div class="list-form-card">

      <%= form_with model: @list do |f| %>

        <div class="form-group">
          <%= f.label :name, "Nome da lista" %>
          <%= f.text_field :name, class: "list-input" %>
        </div>

        <div class="form-group">
          <%= f.label :comment, "Comentário sobre a lista (opcional)" %>
          <%= f.text_area :comment, class: "list-input" %>
        </div>

        <div class="form-group">
          <label>Escolha os filmes</label>

          <div class="movie-grid">

            <% Movie.all.each do |movie| %>

              <label class="movie-select-card">

                <%= check_box_tag "movie_ids[]", movie.id %>

                <img src="<%= movie.poster_url %>">

                <span><%= movie.title %></span>

              </label>

            <% end %>

          </div>

        </div>

        <div class="form-actions">

          <%= f.submit "Criar lista", class: "btn btn-warning btn-lg" %>

          <%= link_to "Cancelar", lists_path,
              class: "btn btn-outline-light btn-lg" %>

        </div>

      <% end %>

    </div>

  </div>

</div>
