<div class="bookmark-page">

  <div class="bookmark-hero">
    <h1>Adicionar filme à lista</h1>
    <p><%= @list.name %></p>
  </div>

  <div class="container">

    <div class="bookmark-card">

      <%= form_with model: [@list, @bookmark] do |f| %>

        <div class="form-group">

          <label>Escolha um filme</label>

          <%= f.collection_select :movie_id, Movie.all, :id, :title,
                { prompt: "Selecione um filme" },
                { class: "movie-select" } %>

        </div>

        <div class="form-group">

          <label>Comentário</label>

          <%= f.text_area :comment,
                placeholder: "O que achou do filme?",
                class: "movie-comment" %>

        </div>

        <div class="bookmark-actions">

          <%= f.submit "Adicionar filme", class: "btn btn-warning btn-lg" %>

          <%= link_to "Cancelar",
              list_path(@list),
              class: "btn btn-outline-light btn-lg" %>

        </div>

      <% end %>

    </div>

  </div>

</div>
